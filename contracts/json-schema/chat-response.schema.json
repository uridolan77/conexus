{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conexus.dev/schemas/chat-response.v1.json",
  "title": "Conexus Chat Completions Response (non-streaming)",
  "description": "Matches backend/app/schemas/openai_compat.py ChatCompletionsResponse.",
  "type": "object",
  "required": ["id", "object", "created", "model", "provider", "fallback_used", "choices", "usage"],
  "properties": {
    "id": { "type": "string" },
    "object": { "type": "string", "const": "chat.completion" },
    "created": { "type": "integer" },
    "model": { "type": "string" },
    "provider": { "type": "string" },
    "fallback_used": { "type": "boolean" },
    "choices": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["index", "message", "finish_reason"],
        "properties": {
          "index": { "type": "integer" },
          "message": {
            "type": "object",
            "required": ["role", "content"],
            "properties": {
              "role": { "type": "string", "enum": ["system", "user", "assistant"] },
              "content": { "type": "string" }
            },
            "additionalProperties": false
          },
          "finish_reason": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "usage": {
      "type": "object",
      "required": ["prompt_tokens", "completion_tokens", "total_tokens"],
      "properties": {
        "prompt_tokens": { "type": "integer", "minimum": 0 },
        "completion_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
