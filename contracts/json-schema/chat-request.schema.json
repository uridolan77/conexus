{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conexus.dev/schemas/chat-request.v1.json",
  "title": "Conexus Chat Completions Request (OpenAI-compatible subset)",
  "description": "Matches backend/app/schemas/openai_compat.py ChatCompletionsRequest for POST /v1/chat/completions.",
  "type": "object",
  "required": ["model", "messages"],
  "properties": {
    "model": { "type": "string", "minLength": 1 },
    "messages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["role", "content"],
        "properties": {
          "role": {
            "type": "string",
            "enum": ["system", "user", "assistant"]
          },
          "content": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "max_tokens": { "type": "integer", "minimum": 1, "maximum": 128000, "default": 4096 },
    "temperature": { "type": "number", "minimum": 0, "maximum": 2, "default": 0.2 },
    "stream": { "type": "boolean", "default": false },
    "top_p": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "stop": {
      "oneOf": [{ "type": "string" }, { "type": "array", "items": { "type": "string" } }, { "type": "null" }]
    },
    "user": { "type": ["string", "null"] },
    "response_format": { "type": ["object", "null"], "additionalProperties": true },
    "seed": { "type": ["integer", "null"] },
    "n": { "type": ["integer", "null"], "minimum": 1, "maximum": 128 },
    "tools": {
      "type": ["array", "null"],
      "items": { "type": "object", "additionalProperties": true }
    },
    "tool_choice": {
      "oneOf": [
        { "type": "object", "additionalProperties": true },
        { "type": "string" },
        { "type": "null" }
      ]
    },
    "logprobs": { "type": ["boolean", "null"] },
    "top_logprobs": { "type": ["integer", "null"], "minimum": 0, "maximum": 20 },
    "presence_penalty": { "type": ["number", "null"], "minimum": -2, "maximum": 2 },
    "frequency_penalty": { "type": ["number", "null"], "minimum": -2, "maximum": 2 }
  },
  "additionalProperties": false
}
