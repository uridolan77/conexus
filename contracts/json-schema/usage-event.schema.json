{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conexus.dev/schemas/usage-event.forward-looking.schema.json",
  "title": "Conexus Usage Event (forward-looking public API shape)",
  "description": "No GET /v1/usage/{trace_id} in Conexus v0. Usage is persisted for admin/BO flows; this schema describes a possible future public envelope.",
  "x-contract-status": "not-implemented",
  "type": "object",
  "required": ["trace_id", "timestamp", "caller", "provider", "model", "usage", "cost", "latency_ms", "status"],
  "properties": {
    "trace_id": { "type": "string" },
    "timestamp": { "type": "string" },
    "caller": { "type": "object", "additionalProperties": true },
    "provider": { "type": "string" },
    "model": { "type": "string" },
    "model_alias": { "type": ["string", "null"] },
    "usage": {
      "type": "object",
      "required": ["input_tokens", "output_tokens", "total_tokens"],
      "properties": {
        "input_tokens": { "type": "integer", "minimum": 0 },
        "output_tokens": { "type": "integer", "minimum": 0 },
        "total_tokens": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "cost": {
      "type": "object",
      "required": ["currency", "estimated"],
      "properties": {
        "currency": { "type": "string" },
        "estimated": { "type": "number", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "latency_ms": { "type": "integer", "minimum": 0 },
    "status": { "type": "string", "enum": ["succeeded", "failed"] }
  },
  "additionalProperties": true
}
