APP_ENV=local
LOG_LEVEL=INFO

# Docker Compose backend should point at the postgres service hostname.
# If running backend directly outside Docker, use localhost instead.
DATABASE_URL=postgresql+asyncpg://conexus:conexus@postgres:5432/conexus

BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_BASE_URL=http://localhost:8000

# Optional: enables Conexus BO adaptation proxy endpoints under /admin/adaptation/*
ADAPTATION_API_BASE_URL=http://localhost:5000

# Internal endpoints for adapter profile runtime registry / activation / observability.
# Used by trusted services (e.g. conexus.adaptation). Never expose to browsers.
#
# Prod requirement (when ADAPTER_PROFILE_REGISTRY_ENABLED=true):
# - not empty
# - not "change-me"
# - length >= 32
INTERNAL_ADAPTER_API_KEY=change-me
ADAPTER_PROFILE_REGISTRY_ENABLED=true
ADAPTER_PROFILE_CANARY_ROUTING_ENABLED=false
ADAPTER_PROFILE_OBSERVABILITY_ENABLED=true

AUTH_SECRET=change-this-local-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_SESSION_TTL_HOURS=12

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=<generate with Fernet>

# Optional for local provider calls and provider test actions.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

LLM_PROVIDER=gateway

# Gateway timeouts (seconds)
LLM_REQUEST_TIMEOUT_SECONDS=60
LLM_STREAM_TIMEOUT_SECONDS=180

# Stale limit reservation repair (unreconciled reservations older than stale threshold)
LIMIT_RESERVATION_STALE_AFTER_SECONDS=900
LIMIT_RESERVATION_FORCE_REPAIR_AFTER_SECONDS=3600

# Model alias routing config
MODEL_ALIASES_PATH=backend/static_config/model_aliases.yaml

# Admin login brute-force protection
ADMIN_LOGIN_MAX_FAILURES=5
ADMIN_LOGIN_WINDOW_SECONDS=600
