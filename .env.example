APP_ENV=local
LOG_LEVEL=INFO

# Docker Compose backend should point at the postgres service hostname.
# If running backend directly outside Docker, use localhost instead.
DATABASE_URL=postgresql+asyncpg://conexus:conexus@postgres:5432/conexus

BACKEND_BASE_URL=http://localhost:8000
FRONTEND_BASE_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_BASE_URL=http://localhost:8000

# Optional: enables Conexus BO adaptation proxy endpoints under /admin/adaptation/*
ADAPTATION_API_BASE_URL=http://localhost:5000

AUTH_SECRET=change-this-local-secret
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin
ADMIN_SESSION_TTL_HOURS=12

# Generate with:
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=<generate with Fernet>

# Optional for local provider calls and provider test actions.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

LLM_PROVIDER=gateway
